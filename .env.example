# AWS credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# S3
S3_BUCKET=krishirakshak-assets
FAISS_S3_BUCKET=krishirakshak-assets
FAISS_S3_KEY=faiss_index/store.pkl

# SageMaker endpoints
SAGEMAKER_REGION=ap-south-1
SAGEMAKER_ENDPOINT=bge-m3-krishirakshak
CLASSIFIER_BACKEND=sagemaker
CLASSIFIER_SAGEMAKER_REGION=ap-south-1
CLASSIFIER_SAGEMAKER_ENDPOINT=krishirakshak-efficientnet-b3

# Local classifier fallback for development/tests only
CLASSIFIER_MODEL_PATH=models_pkl/best_model.pth

# DynamoDB
DYNAMODB_TABLE=krishirakshak-predictions-dev

# API server
HOST=0.0.0.0
PORT=8000
WORKERS=2
DEBUG=false
